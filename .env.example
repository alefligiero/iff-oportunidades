# App environment variables
# Copy this file to .env and adjust as needed

# PostgreSQL connection string used by Prisma and the API
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/iff_oportunidades?schema=public"

# Secret used to sign/verify JWTs (set to a strong random value in production)
JWT_SECRET="dev-super-secret-change-me"

# Admin credentials used only by prisma seed
ADMIN_SEED_EMAIL="admin@iff.edu.br"
ADMIN_SEED_PASSWORD="123456"

# Admin bootstrap for production/one-shot setup
ADMIN_BOOTSTRAP_EMAIL="admin@iff.edu.br"
ADMIN_BOOTSTRAP_PASSWORD="change-this-password"
ADMIN_BOOTSTRAP_FORCE_PASSWORD_UPDATE="false"
